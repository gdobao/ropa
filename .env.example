# Local development example. Copy to `.env` if your shell/tooling loads it.
# Do not commit real secrets.

DB_PASSWORD=ropa
ADMIN_TOKEN=

# Preferred AI provider key. Legacy APP_AI_API_KEY is also supported.
NAN_API_KEY=
APP_AI_API_KEY=

# Set to false to run the app without external AI credentials.
APP_AI_ENABLED=true
