<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender (used by default and dev profile) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{ownerId:-none}] [%X{sessionId:-none}] [%X{runId:-none}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- JSON appender (prod profile) -->
    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>ownerId</includeMdcKeyName>
                <includeMdcKeyName>sessionId</includeMdcKeyName>
                <includeMdcKeyName>runId</includeMdcKeyName>
                <includeMdcKeyName>model</includeMdcKeyName>
                <includeMdcKeyName>endpoint</includeMdcKeyName>
                <fieldNames>
                    <timestamp>[ignore]</timestamp>
                    <version>[ignore]</version>
                    <logger>[ignore]</logger>
                    <thread>[ignore]</thread>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
            </encoder>
        </appender>
    </springProfile>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Chat subsystem debug in dev -->
    <springProfile name="dev">
        <logger name="com.colorinchi.app.service.analytics" level="DEBUG"/>
        <logger name="com.colorinchi.app.service.chat" level="DEBUG"/>
    </springProfile>
</configuration>
